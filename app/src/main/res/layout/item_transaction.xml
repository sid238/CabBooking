<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="60dp"
    android:gravity="center_vertical" android:paddingVertical="8dp">

    <TextView android:id="@+id/txnIcon" android:layout_width="40dp" android:layout_height="40dp"
        android:gravity="center" android:textSize="20sp" />

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:paddingHorizontal="12dp">
        <TextView android:id="@+id/txnTitle" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/textPrimary"
            android:textSize="14sp" android:textStyle="bold" />
        <TextView android:id="@+id/txnDate" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:textColor="@color/grayText"
            android:textSize="11sp" />
    </LinearLayout>

    <TextView android:id="@+id/txnAmount" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textColor="@color/textPrimary"
        android:textSize="15sp" android:textStyle="bold" />
</LinearLayout>
