<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:gravity="center" android:orientation="vertical" android:padding="32dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Rate your ride" android:textColor="@color/textPrimary"
        android:textSize="24sp" android:textStyle="bold" />

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginTop="8dp" android:text="@string/share_feedback"
        android:textColor="@color/grayText" android:textSize="14sp" />

    <de.hdodenhof.circleimageview.CircleImageView android:id="@+id/driverPhoto"
        android:layout_width="72dp" android:layout_height="72dp" android:layout_marginTop="24dp"
        android:src="@drawable/ic_person" />

    <TextView android:id="@+id/driverName" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginTop="8dp"
        android:text="Rajesh Kumar" android:textColor="@color/textPrimary"
        android:textSize="16sp" android:textStyle="bold" />

    <LinearLayout android:id="@+id/starContainer" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginTop="20dp"
        android:orientation="horizontal">
        <TextView android:id="@+id/star1" android:layout_width="48dp" android:layout_height="48dp"
            android:gravity="center" android:text="☆" android:textColor="@color/star"
            android:textSize="40sp" />
        <TextView android:id="@+id/star2" android:layout_width="48dp" android:layout_height="48dp"
            android:gravity="center" android:text="☆" android:textColor="@color/star"
            android:textSize="40sp" />
        <TextView android:id="@+id/star3" android:layout_width="48dp" android:layout_height="48dp"
            android:gravity="center" android:text="☆" android:textColor="@color/star"
            android:textSize="40sp" />
        <TextView android:id="@+id/star4" android:layout_width="48dp" android:layout_height="48dp"
            android:gravity="center" android:text="☆" android:textColor="@color/star"
            android:textSize="40sp" />
        <TextView android:id="@+id/star5" android:layout_width="48dp" android:layout_height="48dp"
            android:gravity="center" android:text="☆" android:textColor="@color/star"
            android:textSize="40sp" />
    </LinearLayout>

    <EditText android:id="@+id/feedbackInput" android:layout_width="match_parent"
        android:layout_height="90dp" android:layout_marginTop="20dp"
        android:background="@drawable/bg_input" android:gravity="start|top"
        android:hint="Share feedback..." android:padding="12dp" android:textSize="14sp" />

    <Button android:id="@+id/submitBtn" android:layout_width="match_parent"
        android:layout_height="52dp" android:layout_marginTop="20dp"
        android:backgroundTint="@color/primary" android:text="@string/submit"
        android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" />

    <Button android:id="@+id/skipBtn" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginTop="12dp"
        android:background="@null" android:stateListAnimator="@null"
        android:text="@string/skip" android:textColor="@color/grayText" />
</LinearLayout>
