<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp" android:layout_height="80dp" android:layout_weight="1"
    android:layout_marginHorizontal="4dp" android:background="@drawable/bg_card"
    android:gravity="center" android:orientation="vertical" android:padding="8dp">

    <TextView android:id="@+id/tileIcon" android:layout_width="40dp" android:layout_height="40dp"
        android:gravity="center" android:text="🚗" android:textSize="24sp" />

    <TextView android:id="@+id/tileName" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textColor="@color/textPrimary"
        android:textSize="12sp" android:textStyle="bold" />

    <TextView android:id="@+id/tileSub" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textColor="@color/grayText"
        android:textSize="10sp" />
</LinearLayout>
