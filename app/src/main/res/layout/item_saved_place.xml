<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content" android:layout_height="wrap_content"
    android:background="@drawable/bg_card" android:gravity="center"
    android:orientation="vertical" android:paddingHorizontal="16dp" android:paddingVertical="10dp"
    android:layout_marginRight="8dp">

    <TextView android:id="@+id/placeLabel" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textColor="@color/textPrimary"
        android:textSize="14sp" android:textStyle="bold" />

    <TextView android:id="@+id/placeAddress" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:textColor="@color/grayText"
        android:maxWidth="150dp" android:singleLine="true" android:textSize="11sp" />
</LinearLayout>
