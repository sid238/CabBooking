<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:gravity="center" android:orientation="vertical" android:padding="32dp">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="Verify OTP" android:textColor="@color/textPrimary" android:textSize="24sp"
        android:textStyle="bold" />

    <TextView android:id="@+id/phoneDisplay" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginTop="8dp"
        android:text="Enter OTP sent to +91 XXXXXXXX"
        android:textColor="@color/grayText" android:textSize="14sp" android:gravity="center" />

    <EditText android:id="@+id/otpInput" android:layout_width="220dp"
        android:layout_height="60dp" android:layout_marginTop="32dp" android:background="@drawable/bg_input"
        android:gravity="center" android:hint="6-digit OTP" android:inputType="number"
        android:maxLength="6" android:textSize="24sp" android:textStyle="bold"
        android:letterSpacing="0.3" />

    <Button android:id="@+id/verifyBtn" android:layout_width="match_parent"
        android:layout_height="54dp" android:layout_marginTop="28dp"
        android:backgroundTint="@color/primary" android:text="@string/verify_text"
        android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" />

    <TextView android:id="@+id/resendBtn" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginTop="20dp"
        android:text="@string/resend_text" android:textColor="@color/primary"
        android:textSize="14sp" android:textStyle="bold" />
</LinearLayout>
