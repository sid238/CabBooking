<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <application
        android:name=".CabBookingApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CabBooking"
        android:usesCleartextTraffic="true">

        <meta-data android:name="com.google.android.geo.API_KEY" android:value="${MAPS_API_KEY}" />

        <activity android:name=".SplashActivity" android:exported="true" android:theme="@style/Theme.CabBooking.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".LoginActivity" />
        <activity android:name=".OTPActivity" />
        <activity android:name=".SetupProfileActivity" />
        <activity android:name=".HomeActivity" android:windowSoftInputMode="adjustResize" />
        <activity android:name=".SearchActivity" />
        <activity android:name=".RideConfirmActivity" />
        <activity android:name=".LiveTrackingActivity" />
        <activity android:name=".RatingActivity" />
        <activity android:name=".ParcelActivity" />
        <activity android:name=".HistoryActivity" />
        <activity android:name=".WalletActivity" />
        <activity android:name=".ProfileActivity" />
        <activity android:name=".SupportActivity" />
        <activity android:name=".AboutActivity" />
        <activity android:name=".UpiPaymentActivity" />
    </application>
</manifest>
